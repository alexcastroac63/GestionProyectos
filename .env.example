# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AWS S3 Simulated Local Credentials (referencia para docker integration)
AWS_S3_ENDPOINT="http://localhost:9000"
AWS_S3_ACCESS_KEY_ID="aws_mock_key_id"
AWS_S3_SECRET_ACCESS_KEY="aws_mock_secret_key"
AWS_S3_BUCKET_NAME="soporte-pmo-bucket"
AWS_S3_REGION="us-east-1"

# Session Security (Finding 2)
JWT_SECRET="secure-lifecycle-pmo-pmo-cluster-stack-key-2026"

# Portainer / Docker Compose DB Secrets (Finding 6)
POSTGRES_USER="postgres_user"
POSTGRES_PASSWORD="postgres_secure_pass"
POSTGRES_DB="pmo_database"

# S3 Backup Storage root user & secret (Finding 6)
MINIO_ROOT_USER="aws_mock_key_id"
MINIO_ROOT_PASSWORD="aws_mock_secret_key"

